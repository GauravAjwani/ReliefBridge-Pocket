# Copy to .env for a real Slack sandbox run. The default demo path works without
# paid APIs and can run with mocked Slack search data.
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_SIGNING_SECRET=your-signing-secret

# Free-first mode: keep true until your Slack sandbox has RTS access.
RELIEFBRIDGE_MOCK_RTS=true

# Optional. If omitted, the app uses deterministic triage summaries.
LOCAL_MODEL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL_NAME=llama3.1
